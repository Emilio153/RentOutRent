{
	"info": {
		"name": "Alquiler Vacacional API (MVP) - Sin Variables",
		"description": "Colección completa con todos los CRUDs y Casos de Uso del Backend Spring Boot (URLs directas a localhost).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Personas / Auth",
			"item": [
				{
					"name": "Listar Todas las Personas",
					"request": {
						"method": "GET",
						"url": { "raw": "http://localhost:8092/api/personas", "host": ["localhost"], "port": "8092", "path": ["api", "personas"] }
					}
				},
				{
					"name": "Login (Autenticación Fake)",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"juan@test.com\",\n    \"password\": \"123456\"\n}"
						},
						"url": { "raw": "http://localhost:8092/api/personas/login", "host": ["localhost"], "port": "8092", "path": ["api", "personas", "login"] }
					}
				}
			]
		},
