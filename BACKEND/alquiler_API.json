{
	"info": {
		"name": "Alquiler Vacacional API (MVP) - ARQUITECTURA LIMPIA",
		"description": "Colección completa con todos los CRUDs adaptados a la nueva entidad única de Usuario y roles JWT.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Usuarios / Auth",
			"item": [
				{
					"name": "A. Registrar Usuario (Paco)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombre\": \"Paco Nuevo\",\n    \"dni\": \"12345678X\",\n    \"email\": \"paco@nuevo.com\",\n    \"telefono\": \"+34600112233\",\n    \"password\": \"mi_password_segura\",\n    \"confirmPassword\": \"mi_password_segura\",\n    \"tipoUsuario\": \"USUARIO\"\n}"
						},
						"url": {
							"raw": "http://localhost:8092/api/auth/register",
							"host": ["localhost"],
							"port": "8092",
							"path": ["api", "auth", "register"]
						}
					}
				},
				{
					"name": "B. Login (¡Guarda el token!)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.token) {",
									"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"    console.log(\"¡Token guardado con éxito!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"alex@test.com\",\n    \"password\": \"1234\"\n}"
						},
						"url": {
							"raw": "http://localhost:8092/api/auth/login",
							"host": ["localhost"],
							"port": "8092",
							"path": ["api", "auth", "login"]
						}
					}
				},
				{
					"name": "Listar Todos los Usuarios",
					"request": {
						"auth": {
							"type": "bearer",
